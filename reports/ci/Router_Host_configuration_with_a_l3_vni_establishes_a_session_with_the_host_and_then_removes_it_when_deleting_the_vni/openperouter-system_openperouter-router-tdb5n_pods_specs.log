        "containers": [
            {
                "name": "frr",
                "image": "quay.io/openperouter/router:main-grout",
                "command": [
                    "/bin/sh",
                    "-c",
                    "TIMEOUT=60\nWAITED=0\nuntil [ -e /var/run/netns/perouter ]; do\n  echo \"Waiting for named netns /var/run/netns/perouter...\"\n  sleep 1\n  WAITED=$((WAITED + 1))\n  if [ \"$WAITED\" -ge \"$TIMEOUT\" ]; then\n    echo \"Timed out waiting for named netns after ${TIMEOUT}s\"\n    exit 1\n  fi\ndone\nexec nsenter --net=/var/run/netns/perouter /sbin/tini -- /usr/lib/frr/docker-start\n"
                ],
                "env": [
                    {
                        "name": "TINI_SUBREAPER",
                        "value": "true"
                    },
                    {
                        "name": "GROUT_SOCK_PATH",
                        "value": "/var/run/grout/grout.sock"
                    }
                ],
                "resources": {},
                "volumeMounts": [
                    {
                        "name": "frr-sockets",
                        "mountPath": "/var/run/frr"
